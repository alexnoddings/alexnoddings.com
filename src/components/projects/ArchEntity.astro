---
type Props = {
  x: number;
  y: number;
  w: number;
  h: number;
  stroke: string;
  fill: string;
}

const { x, y, w, h, stroke, fill } = Astro.props;
---

<g transform={`translate(${x}, ${y})`}>
  <rect x={0} y={0} width={w} height={h} fill={fill} stroke={stroke} stroke-width="1" stroke-dasharray="4" rx="6" ry="6" />
  <g fill={stroke}>
  <slot/>
  </g>
</g>
